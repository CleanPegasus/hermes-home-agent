# Copy this file to deploy/.env.production and replace every change-me value.

# Public HTTP entrypoint
HTTP_PORT=80
PUBLIC_BASE_URL=http://your-vps-hostname-or-ip
CORS_ORIGINS=http://your-vps-hostname-or-ip
VITE_API_BASE=

# nginx Basic Auth. Generate this file before starting the stack.
NGINX_HTPASSWD_HOST_PATH=./nginx/.htpasswd
NGINX_BASIC_AUTH_REALM=Hermes Home

# App auth and runtime
HOME_API_TOKEN=change-me
HERMES_ENV=production
HERMES_STRICT_DEPLOYMENT_CHECKS=false
LOG_LEVEL=info
CODEX_ENABLED=false

# Postgres
POSTGRES_DB=hermes_home
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me

# Upstream Hermes handoff. Leave empty to use the deterministic fallback agent.
# If set, the command must be runnable inside the app container.
AGENT_CMD=

# Obsidian vault mounted into the app container at /data/obsidian-vault.
OBSIDIAN_VAULT_HOST_PATH=./data/obsidian-vault

# Todoist todo provider (Todoist cloud API; no container to run).
# Get an API token from Todoist: Settings -> Integrations -> Developer.
TODOIST_TOKEN=change-me
# Optional alternative to TODOIST_TOKEN: read the token from a file.
TODOIST_TOKEN_FILE=
# Project Hermes Home uses for captured todos. Leave blank for the Inbox.
TODOIST_DEFAULT_PROJECT_ID=
# Request timeout (seconds) for Todoist API calls.
TODOIST_TIMEOUT_SECONDS=10

# Embeddings / indexing for daily index and /api/search.
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# In-process scheduler (daily reindex + periodic "For You" enrichment).
HERMES_SCHEDULER_ENABLED=true
HERMES_REINDEX_HOUR=3
HERMES_FORYOU_INTERVAL_MINUTES=60
