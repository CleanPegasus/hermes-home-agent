#!/usr/bin/env python3
from __future__ import annotations

import argparse
import base64
import json
import os
import sys
import urllib.error
import urllib.request


def main() -> int:
    parser = argparse.ArgumentParser(description="Check a Hermes Home API or same-origin nginx deployment.")
    parser.add_argument("--base-url", default=default_base_url(), help="Origin to check, for example http://127.0.0.1:8000")
    parser.add_argument("--token", default=os.getenv("HOME_API_TOKEN", ""), help="HOME_API_TOKEN for direct API checks")
    parser.add_argument("--basic", default="", help="username:password for public Basic Auth checks")
    parser.add_argument(
        "--expect-nginx-injection",
        action="store_true",
        help="Do not send Bearer auth; expect nginx Basic Auth to inject Authorization: Bearer upstream",
    )
    args = parser.parse_args()

    url = args.base_url.rstrip("/") + "/api/deployment/self-check"
    headers = {"accept": "application/json"}
    if args.expect_nginx_injection:
        if args.basic:
            headers["authorization"] = "Basic " + base64.b64encode(args.basic.encode("utf-8")).decode("ascii")
    else:
        if not args.token:
            print("HOME_API_TOKEN is required unless --expect-nginx-injection is used", file=sys.stderr)
            return 2
        headers["authorization"] = f"Bearer {args.token}"

    request = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            payload = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        print(f"self-check failed: HTTP {exc.code} {body}", file=sys.stderr)
        return 1
    except OSError as exc:
        print(f"self-check failed: {exc}", file=sys.stderr)
        return 1

    print(f"ok: {payload.get('ok')}")
    for item in payload.get("checks", []):
        print(f"{item.get('status')}\t{item.get('code')}\t{item.get('message')}")
    return 0 if payload.get("ok") else 1


def default_base_url() -> str:
    if os.getenv("PUBLIC_BASE_URL"):
        return os.environ["PUBLIC_BASE_URL"]
    return f"http://127.0.0.1:{os.getenv('SERVER_PORT', '8000')}"


if __name__ == "__main__":
    raise SystemExit(main())
