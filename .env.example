# Hermes Home app server
HOME_API_TOKEN=dev-token
DATABASE_URL=sqlite:///./hermes-home.db
AGENT_CMD=
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOG_LEVEL=info
HERMES_ENV=development

# Agent and MCP conventions
# The app server sets HERMES_HOME_JOB_ID for each agent invocation.
HERMES_HOME_JOB_ID=
HERMES_HOME_AGENT_NAME=hermes
HERMES_HOME_PAGE_SKILL=deliver-as-page
HERMES_HOME_TILE_SKILL=keep-tiles-fresh
HERMES_HOME_NOTE_SKILL=categorize-notes

# Obsidian vault used as the source of truth for Hermes notes.
# Unset leaves the notes surface in a connect-vault state.
OBSIDIAN_VAULT_PATH=

# Todoist todo provider (Todoist cloud API)
# Get an API token from Todoist: Settings -> Integrations -> Developer.
# Hermes Home stores only Todoist task IDs plus cached display fields.
TODOIST_TOKEN=
# Optional alternative to TODOIST_TOKEN: read the token from a file
# (handy for secret-mounted deployments).
TODOIST_TOKEN_FILE=
# Project Hermes Home uses for captured todos. Leave blank for the Inbox.
TODOIST_DEFAULT_PROJECT_ID=
# Request timeout (seconds) for Todoist API calls.
TODOIST_TIMEOUT_SECONDS=10

# Embeddings / indexing for daily index and /api/search.
# EMBEDDING_PROVIDER: "openai" (default) or "null"/empty to disable embeddings.
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# In-process scheduler (daily reindex + periodic "For You" enrichment).
HERMES_SCHEDULER_ENABLED=true
# Hour of day (0-23) to run the daily reindex.
HERMES_REINDEX_HOUR=3
# Minutes between "For You" / saved-items enrichment passes.
HERMES_FORYOU_INTERVAL_MINUTES=60

# HOME_API_TOKEN (above) is also the Bearer token an Apple Shortcut sends to
# POST /api/saved-items when sharing links into the Pocket-style "For You" tile.

# Docker Compose Postgres defaults
POSTGRES_DB=hermes_home
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_dev_password
POSTGRES_PORT=5432

# Web client
# Leave blank for same-origin nginx deployments. Local Vite dev can pass
# VITE_API_BASE=http://127.0.0.1:8000 on the command line.
VITE_API_BASE=

# Optional production settings
PUBLIC_BASE_URL=http://127.0.0.1:8000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PGDATA=/var/lib/postgresql/data
CODEX_ENABLED=false
HERMES_STRICT_DEPLOYMENT_CHECKS=false
