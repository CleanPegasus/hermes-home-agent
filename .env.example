# Hermes Home app server
HOME_API_TOKEN=dev-token
DATABASE_URL=sqlite:///./hermes-home.db
AGENT_CMD=
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOG_LEVEL=info

# Agent and MCP conventions
# The app server sets HERMES_HOME_JOB_ID for each agent invocation.
HERMES_HOME_JOB_ID=
HERMES_HOME_AGENT_NAME=hermes
HERMES_HOME_PAGE_SKILL=deliver-as-page
HERMES_HOME_TILE_SKILL=keep-tiles-fresh
HERMES_HOME_NOTE_SKILL=categorize-notes

# Docker Compose Postgres defaults
POSTGRES_DB=hermes_home
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_dev_password
POSTGRES_PORT=5432

# Web client
VITE_API_BASE=http://127.0.0.1:8000
VITE_HOME_API_TOKEN=dev-token

# Optional production settings
PUBLIC_BASE_URL=http://127.0.0.1:8000
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PGDATA=/var/lib/postgresql/data

